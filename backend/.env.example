# Server
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.com

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/triprodeo?schema=public"

# JWT Secrets — generate strong random strings for production
JWT_SECRET=change_me_to_a_long_random_secret
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin defaults (seeded on first boot)
ADMIN_DEFAULT_PASSWORD=change_me_in_production
ADMIN_DEFAULT_EMAIL=admin@triprodeo.com

# CMS
CMS_ADMIN_SECRET=change_me_in_production

# Site metadata (used in SEO / sitemap / og tags)
SITE_URL=https://triprodeo.com
SITE_NAME=Triprodeo
SITE_DESCRIPTION=India's premier luxury villa and resort booking platform
